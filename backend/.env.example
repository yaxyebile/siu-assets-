# ===========================================
# SIU Assets Backend - Environment Variables
# ===========================================
# Copy this file to .env and fill in values

# Server
NODE_ENV=production
PORT=5000

# MongoDB Atlas Connection String
# Get this from: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/siu-assets?retryWrites=true&w=majority

# JWT Secret (use a long random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Frontend URL (your Vercel deployment URL)
# You can add multiple URLs separated by commas
FRONTEND_URL=https://your-app.vercel.app

# SMS Service (optional)
SMS_API_KEY=
SMS_SENDER_ID=SIU-Assets
